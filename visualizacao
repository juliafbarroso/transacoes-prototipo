<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SIJ — Transação</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Inter,sans-serif;font-size:13px;color:#262626;background:#F5F5F5;min-height:100vh;display:flex;flex-direction:column}
.topbar{background:#0D2D42;height:48px;display:flex;align-items:center;padding:0 20px;gap:10px;flex-shrink:0}
.logo{font-size:14px;font-weight:600;color:#fff}
.ds-badge{background:#093671;color:#B5D4F4;font-size:10px;font-weight:600;padding:2px 7px;border-radius:4px;letter-spacing:.05em}
.shell{display:flex;flex-direction:column;flex:1;overflow:hidden}
.subhd{background:#fff;border-bottom:.5px solid #D4D4D4;padding:0 20px;flex-shrink:0}
.bc{font-size:11px;color:#6D6D6E;display:flex;align-items:center;gap:5px;padding:10px 0 5px}
.bc b{color:#262626;font-weight:500}
.bc .sep{color:#A3A3A3}
.strow{display:flex;align-items:center;justify-content:space-between;padding:5px 0 8px}
.strow-left{display:flex;align-items:center;gap:8px}
.strow-right{display:flex;align-items:center;gap:8px}
.pill{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:3px 10px;border-radius:9999px}
.pill-warn{background:#FFFBE0;color:#867400}
.pill-open{background:#F5F5F5;color:#6D6D6E}
.tabs{display:flex}
.tab{padding:9px 18px;font-size:12px;border:none;background:none;cursor:pointer;color:#6D6D6E;border-bottom:2px solid transparent;font-family:inherit}
.tab:hover{color:#262626}
.tab.on{color:#008633;border-bottom-color:#008633;font-weight:600}
.main{flex:1;overflow:auto;padding:16px 20px}
.panel{display:none}
.panel.on{display:block}

/* layout resumo */
.resumo-grid{display:grid;grid-template-columns:280px 1fr;gap:14px;align-items:start}

/* cards */
.card{background:#fff;border:.5px solid #D4D4D4;border-radius:12px;overflow:hidden;margin-bottom:12px}
.card:last-child{margin-bottom:0}
.card-hd{padding:12px 16px;border-bottom:.5px solid #F0F0F0;display:flex;align-items:center;justify-content:space-between;cursor:pointer;user-select:none}
.card-hd:hover{background:#FAFAFA}
.card-title{font-size:13px;font-weight:600;color:#262626}
.card-body{padding:16px}

/* campos */
.lbl{font-size:10px;color:#A3A3A3;display:block;margin-bottom:2px;letter-spacing:.02em}
.val{font-size:12px;color:#262626;font-weight:500;line-height:1.4;display:block}
.val-link{font-size:12px;color:#185FA5;font-weight:500;cursor:pointer}
.val-link:hover{text-decoration:underline}
.frow{margin-bottom:10px}
.divider{height:.5px;background:#F0F0F0;margin:12px 0}
.sec-lbl{font-size:10px;font-weight:600;color:#A3A3A3;text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:10px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px 16px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px 16px;margin-bottom:10px}
.icon-row{display:flex;align-items:flex-start;gap:8px;margin-bottom:10px}
.icon-wrap{margin-top:1px;flex-shrink:0;color:#A3A3A3}

/* processo card esquerda */
.proc-num{font-size:13px;font-weight:700;color:#262626;line-height:1.3;word-break:break-all}
.risco-row{display:flex;align-items:center;gap:6px;padding:6px 0;font-size:11px;color:#6D6D6E}

/* créditos lista */
.credito-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:.5px solid #F0F0F0;cursor:pointer}
.credito-row:last-child{border-bottom:none}
.credito-row:hover{background:#FAFAFA;margin:0 -16px;padding:10px 16px}
.credito-num{width:22px;height:22px;border-radius:50%;background:#0D2D42;color:#fff;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.credito-info{flex:1;min-width:0}
.credito-cedente{font-size:12px;font-weight:600;color:#262626}
.credito-tipo{font-size:11px;color:#6D6D6E;margin-top:1px}
.credito-vals{display:flex;flex-direction:column;align-items:flex-end;gap:2px;flex-shrink:0}
.credito-dep{font-size:12px;font-weight:600;color:#0C447C}
.tag{display:inline-flex;padding:2px 8px;border-radius:9999px;font-size:10px;font-weight:600}
.tag-open{background:#FFFBE0;color:#867400}
.tag-wait-pay{background:#E6F1FB;color:#0C447C}
.tag-wait-rec{background:#EAF3DE;color:#3B6D11}
.tag-done{background:#EAF3DE;color:#3B6D11}
.tag-lost{background:#FCEBEB;color:#A32D2D}
.tag-cancel{background:#F5F5F5;color:#6D6D6E}
.tag-modelo{background:#F5F5F5;color:#525252;font-weight:500}
.vinc-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:.5px solid #F0F0F0;font-size:11px}
.vinc-row:last-child{border-bottom:none}
.vinc-tag{background:#F5F5F5;color:#6D6D6E;padding:2px 8px;border-radius:9999px;font-size:10px;font-weight:500}

/* registros */
.reg-input-wrap{border:.5px solid #D4D4D4;border-radius:10px;padding:10px 12px;display:flex;gap:10px;align-items:flex-start;margin-bottom:8px}
.reg-textarea{flex:1;border:none;outline:none;resize:none;font-size:12px;color:#262626;background:transparent;font-family:inherit;min-height:36px}
.reg-textarea::placeholder{color:#A3A3A3}
.reg-filters{display:flex;gap:6px;margin-bottom:10px}
.reg-btn{padding:3px 10px;border-radius:9999px;font-size:11px;border:.5px solid #D4D4D4;background:#fff;cursor:pointer;color:#6D6D6E;font-family:inherit}
.reg-btn.on{background:#EAF3DE;color:#3B6D11;border-color:#639922;font-weight:600}
.search-wrap{position:relative;margin-bottom:8px}
.search-input{width:100%;height:30px;border:.5px solid #D4D4D4;border-radius:8px;padding:0 32px 0 28px;font-size:11px;color:#262626;background:#fff;outline:none;font-family:inherit}
.hint{font-size:10px;color:#A3A3A3;margin-bottom:10px}
.reg-card{border:.5px solid #D4D4D4;border-radius:10px;margin-bottom:8px;overflow:hidden}
.avatar{width:28px;height:28px;border-radius:50%;background:#B5D4F4;color:#0C447C;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0}
.avatar.g{background:#C0DD97;color:#3B6D11}
.avatar.sm{width:22px;height:22px;font-size:9px}
.mention{background:#E6F1FB;color:#185FA5;border-radius:3px;padding:1px 4px;font-size:11px;font-weight:500}
.link-tag{color:#185FA5;font-size:11px;font-weight:500}
.reply-card{background:#FAFAFA;border:.5px solid #E5E5E5;border-radius:8px;padding:9px 11px;margin-top:7px}
.reply-btn{background:none;border:none;cursor:pointer;color:#6D6D6E;font-size:11px;display:inline-flex;align-items:center;gap:4px;margin-top:6px;padding:0;font-family:inherit}
.alt-card{background:#FAFAFA;border:.5px solid #E5E5E5;border-radius:8px;padding:10px 12px;margin-bottom:8px}

/* comercial */
.comercial-grid{display:flex;flex-direction:column;gap:12px}
.credito-detail{border:.5px solid #D4D4D4;border-radius:12px;overflow:hidden;background:#fff;margin-bottom:0}
.credito-detail-hd{display:flex;align-items:center;gap:10px;padding:12px 16px;border-bottom:.5px solid #F0F0F0;cursor:pointer;user-select:none;background:#FAFAFA}
.credito-detail-hd:hover{background:#F5F5F5}
.credito-detail-body{padding:16px}
.calc-block{background:#F5F5F5;border-radius:8px;padding:12px 14px;margin-top:14px;border:.5px solid #E5E5E5}
.calc-title{font-size:10px;font-weight:600;color:#A3A3A3;text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px}
.calc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.ci label{font-size:10px;color:#A3A3A3;display:block;margin-bottom:2px}
.ci span{font-size:13px;font-weight:600;color:#262626}
.ci span.hl{color:#0C447C}
.calc-divider{grid-column:1/-1;height:.5px;background:#E5E5E5;margin:2px 0}
.exc-list{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px}
.exc-tag{background:#FAEEDA;color:#633806;border-radius:4px;padding:2px 8px;font-size:11px;font-weight:500}
.df-block{background:#EBF4FD;border:.5px solid #85B7EB;border-radius:8px;padding:12px 14px;margin-top:10px}
.df-title{font-size:10px;font-weight:600;color:#0C447C;text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px}

/* consolidado financeiro */
.consolidated{background:#fff;border:.5px solid #D4D4D4;border-radius:12px;padding:16px;margin-bottom:12px}
.consolidated-title{font-size:13px;font-weight:600;color:#262626;margin-bottom:12px}

/* parceria */
.parceria-block{background:#FAEEDA;border:.5px solid #FAC775;border-radius:8px;padding:12px 14px;margin-top:10px}
.parceria-title{font-size:10px;font-weight:600;color:#633806;text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px}

button.icon-btn{background:none;border:none;cursor:pointer;color:#A3A3A3;display:flex;align-items:center}
button.icon-btn:hover{color:#262626}
.edit-btn{display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:6px;border:.5px solid #D4D4D4;background:#fff;font-size:11px;font-weight:500;cursor:pointer;color:#262626;font-family:inherit}
.edit-btn:hover{background:#F5F5F5}
</style>
</head>
<body>

<div class="topbar">
  <span class="logo">JusCash</span>
  <span class="ds-badge">SIJ</span>
</div>

<div id="mode-vis" style="display:flex;flex-direction:column;flex:1">
<div class="shell">
  <div class="subhd">
    <div class="bc">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2L4 6l4 4"/></svg>
      <span>Transações</span><span class="sep">›</span><b>Transação</b>
    </div>
    <div class="strow">
      <div class="strow-left">
        <span class="pill pill-warn">Em andamento</span>
        <span style="font-size:11px;color:#A3A3A3">2 créditos · 1 aguarda pagamento</span>
      </div>
      <div class="strow-right">
        <button class="edit-btn" onclick="setMode('edit')">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.5 1.5l2 2L3 11H1v-2L8.5 1.5z"/></svg>
          Editar transação
        </button>
      </div>
    </div>
    <div class="tabs">
      <button class="tab on" onclick="goTab('resumo',this)">Resumo</button>
      <button class="tab" onclick="goTab('comercial',this)">Comercial</button>
      <button class="tab" onclick="goTab('financeiro',this)">Financeiro</button>
      <button class="tab" onclick="goTab('infos',this)">Informações adicionais</button>
      <button class="tab" onclick="goTab('anexos',this)">Anexos</button>
    </div>
  </div>

  <div class="main">

    <!-- ══ RESUMO ══ -->
    <div class="panel on" id="panel-resumo">
      <div class="resumo-grid">

        <!-- col esquerda -->
        <div>
          <div class="card">
            <div class="card-body">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:10px">
                <span class="proc-num">0000000-00.0000.0.00.0000</span>
                <button class="icon-btn"><svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="3" cy="7.5" r="1.2"/><circle cx="7.5" cy="7.5" r="1.2"/><circle cx="12" cy="7.5" r="1.2"/></svg></button>
              </div>

              <div class="risco-row">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6.5 1L1 12h11L6.5 1z"/><line x1="6.5" y1="5" x2="6.5" y2="8"/><circle cx="6.5" cy="10" r=".5" fill="currentColor"/></svg>
                <span>Risco jurídico</span>
                <span style="margin-left:auto;font-weight:600;font-size:12px;color:#262626">2</span>
              </div>

              <div class="divider"></div>
              <span class="sec-lbl">IDs do processo</span>

              <div class="icon-row">
                <span class="icon-wrap"><svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="11" height="11" rx="1.5"/><path d="M4 6.5h5M6.5 4v5"/></svg></span>
                <div><span class="lbl">ID SIJ</span><span class="val">918191</span></div>
              </div>
              <div class="icon-row">
                <span class="icon-wrap"><svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 2.5H2.5A1.5 1.5 0 001 4v7a1.5 1.5 0 001.5 1.5H10A1.5 1.5 0 0011.5 11V8.5"/><path d="M8 1H12V5"/><path d="M12 1L5.5 7.5"/></svg></span>
                <div><span class="lbl">ID CRM</span><span class="val">918191</span></div>
              </div>
              <div class="icon-row">
                <span class="icon-wrap"><svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 2.5H2.5A1.5 1.5 0 001 4v7a1.5 1.5 0 001.5 1.5H10A1.5 1.5 0 0011.5 11V8.5"/><path d="M8 1H12V5"/><path d="M12 1L5.5 7.5"/></svg></span>
                <div><span class="lbl">ID iiLex</span><span class="val-link">2222</span></div>
              </div>
              <div class="icon-row" style="margin-bottom:0">
                <span class="icon-wrap"><svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 2.5H2.5A1.5 1.5 0 001 4v7a1.5 1.5 0 001.5 1.5H10A1.5 1.5 0 0011.5 11V8.5"/><path d="M8 1H12V5"/><path d="M12 1L5.5 7.5"/></svg></span>
                <div><span class="lbl">ID Loy</span><span class="val-link">2222</span></div>
              </div>

              <div class="divider"></div>
              <span class="sec-lbl">Processo vinculado</span>
              <div class="vinc-row"><span class="val-link" style="font-size:11px">0000000-00.0000.0.00.0000</span><span class="vinc-tag">Renegociação</span></div>
            </div>
          </div>
        </div>

        <!-- col direita -->
        <div>
          <!-- informações do processo -->
          <div class="card">
            <div class="card-hd" onclick="togCard(this)">
              <span class="card-title">Informações do processo</span>
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="#A3A3A3" stroke-width="1.5"><path d="M2 4.5l4.5 4.5 4.5-4.5"/></svg>
            </div>
            <div class="card-body">
