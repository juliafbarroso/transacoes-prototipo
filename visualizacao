var eModSels={};
function eToggleMs(ddId){
  var dd=document.getElementById(ddId+'-dd');
  var tr=ddId.replace('-dd','');
  if(!dd)return;
  dd.classList.toggle('open');
}
function eToggleModOpt(creditId,val,label,optEl){
  var key=creditId+'-mod';
  if(!eModSels[key])eModSels[key]=new Set();
  var sel=eModSels[key];
  var chk=optEl.querySelector('input');
  if(sel.has(val)){sel.delete(val);if(chk)chk.checked=false;optEl.style.background='';}
  else{sel.add(val);if(chk)chk.checked=true;optEl.style.background='#EBF4FD';}
  var ph=document.getElementById(creditId+'-mod-ph');
  if(ph){if(sel.size===0){ph.textContent='Selecione';}else{ph.textContent=sel.size+' selecionado(s)';}}
  var dfWrap=document.getElementById(creditId+'-df-wrap');
  if(dfWrap)dfWrap.style.display=sel.has('desagio_flex')?'block':'none';
}

function eRmCredit(id){var e=document.getElementById(id);if(e)e.remove();delete eCredits[id];eRecalcAll();}

function eRcCredit(id){
  var bruto=eNum((document.getElementById(id+'-bruto')||{}).value);
  var ir=eNum((document.getElementById(id+'-ir')||{}).value);
  var des=parseFloat(((document.getElementById(id+'-des')||{}).value||'0').replace(',','.'))||0;
  var abat=eNum((document.getElementById(id+'-abat')||{}).value);
  var ded=bruto-ir;
  var dep=ded*(1-des/100);
  var tot=dep-abat;
  eSetI(id+'-ded',eBrl(ded));eSetI(id+'-dep',eBrl(dep));eSetI(id+'-total',eBrl(tot));
  var dfWrap=document.getElementById(id+'-df-wrap');
  if(dfWrap&&dfWrap.style.display!=='none'){
    var dfPct=parseFloat(((document.getElementById(id+'-df-pct')||{}).value||'0').replace(',','.'))||0;
    var dfDep=tot*(1-dfPct/100);var dfRec=tot-dfDep;
    eSetI(id+'-df-dep',eBrl(dfDep));eSetI(id+'-df-rec',eBrl(dfRec));eSetI(id+'-df-dev',eBrl(dfRec));
  }
  eCredits[id]={bruto:bruto,ir:ir,desagio:des,abatimento:abat,deduzido:ded,deposito:dep,depTotal:tot};
  eRecalcAll();
}

function eRecalcAll(){
  var tB=0,tI=0,tD=0,tA=0,dN=0,dDen=0;
  Object.keys(eCredits).forEach(function(id){var c=eCredits[id];if(!c)return;tB+=c.bruto||0;tI+=c.ir||0;tD+=c.deposito||0;tA+=c.abatimento||0;dN+=(c.desagio||0)*(c.bruto||0);dDen+=c.bruto||0;});
  var depFinal=tD-tA;
  var dMed=dDen>0?dN/dDen:0;
  var receita=tB-depFinal;
  var dAlvo=parseFloat((document.getElementById('e-g-desagio')||{value:'0'}).value)||0;
  var efic=dAlvo>0?dMed/dAlvo*100:0;
  eSetT('e-cf-contrato',eBrl(tB));eSetT('e-cf-desagio',ePct(dMed));eSetT('e-cf-ir',eBrl(tI));eSetT('e-cf-deposito',eBrl(tD));
  eSetT('e-cf-abatimento',eBrl(tA));eSetT('e-cf-depfinal',eBrl(depFinal));eSetT('e-cf-receita',eBrl(receita));
  eSetT('e-cf-eficiencia',dAlvo>0?ePct(efic):'—');
  eSetT('e-sv-ref',eBrl(tB-tI));eSetT('e-sv-deptotal',eBrl(depFinal));
  eRecalcParc();eUpdateSum();
}
function eRecalcParc(){
  if(!(document.getElementById('e-chkParc')||{}).checked)return;
  var base=eNum((document.getElementById('e-cf-depfinal')||{}).textContent);
  var pPct=parseFloat(((document.getElementById('e-parc-pct')||{}).value||'0').replace(',','.'))||0;
  eSetI('e-parc-valor',eBrl(base*pPct/100));
}

var eMCount=0,eMovSels={};
function eAddMov(){
  eMCount++;var n=eMCount,id='emov'+n;eMovSels[id]=new Set();
  var d=document.createElement('div');d.className='e-mov-item';d.id=id;
  d.innerHTML='<div class="e-mov-hd">'+
    '<select class="e-tipo-sel" onchange="eRenderMov(\''+id+'\',this.value)">'+
      '<option value="">Selecione o tipo</option><option value="dep">Depósito</option><option value="rec">Recebimento</option><option value="dev">Devolução</option>'+
    '</select>'+
    '<button class="e-rm-btn" style="margin-left:auto" onclick="eRemoveMov(\''+id+'\')">Remover</button>'+
  '</div><div id="'+id+'-f"></div>';
  document.getElementById('e-mov-list').appendChild(d);
}
function eRemoveMov(id){var e=document.getElementById(id);if(e)e.remove();delete eMovSels[id];eUpdateSum();}
function eRenderMov(id,tipo){
  var c=document.getElementById(id+'-f');
  if(tipo==='dep'){
    c.innerHTML='<div class="e-row e-col3"><div class="e-field"><label>Data do depósito</label><input type="date"/></div><div class="e-field"><label>Valor depositado (R$)</label><input type="text" id="'+id+'-vd" placeholder="R$ 0,00" oninput="eMaskMoney(this);eUpdateSum()"/></div><div class="e-field"><label>Origem do funding</label><select><option value="">Selecione</option><option>JusCash</option><option>Debênture</option><option>Investidores</option></select></div></div>';
  } else if(tipo==='rec'){
    var irTotal=Object.values(eCredits).reduce(function(s,c){return s+(c.ir||0);},0);
    c.innerHTML='<div class="e-row e-col2"><div class="e-field"><label>Valor recebido</label><input type="text" id="'+id+'-vr" placeholder="R$ 0,00" oninput="eMaskMoney(this);eUpdateSum()"/></div><div class="e-field"><label>Data do recebimento</label><input type="date"/></div></div>'+
      '<div class="e-toggle-row"><label class="e-toggle"><input type="checkbox" id="'+id+'-parcial" onchange="eToggleParcial(\''+id+'\')"/><span class="e-tslider"></span></label><span>Recebimento parcial</span></div>'+
      '<div id="'+id+'-pend-wrap" style="display:none;margin-bottom:12px"><div class="e-field"><label>Valor pendente</label><input class="e-calc" type="text" id="'+id+'-pendente" readonly placeholder="R$ 0,00"/></div></div>'+
      '<div class="e-ir-block"><div class="e-ir-title">Imposto de renda</div>'+
        '<div class="e-row e-col3"><div class="e-field"><label>IR previsto</label><input class="e-calc" type="text" id="'+id+'-irp" value="'+eBrl(irTotal)+'" readonly/></div><div class="e-field"><label>IR realizado</label><input type="text" id="'+id+'-irr" placeholder="R$ 0,00" oninput="eMaskMoney(this)"/></div><div class="e-field"><label>Devolução IR</label><input class="e-calc" type="text" id="'+id+'-ird" readonly placeholder="R$ 0,00"/></div></div>'+
        '<div class="e-row e-col2"><div class="e-field"><label>Status devolução</label><select><option value="">Selecione</option><option>Devolver</option><option>Não devolver</option><option>Devolvido</option><option>Cliente deve IR</option></select></div><div></div></div>'+
      '</div>';
  } else if(tipo==='dev'){
    c.innerHTML='<div class="e-row e-col3"><div class="e-field"><label>Data da devolução</label><input type="date"/></div><div class="e-field"><label>Valor devolvido (R$)</label><input type="text" placeholder="R$ 0,00" oninput="eMaskMoney(this)"/></div><div class="e-field"><label>Tipo de devolução</label><select><option value="">Selecione</option><option>IR</option><option>Deságio flexível</option></select></div></div>';
  } else {c.innerHTML='';}
}
function eToggleParcial(id){
  var chk=document.getElementById(id+'-parcial');
  var wrap=document.getElementById(id+'-pend-wrap');
  if(chk&&wrap)wrap.style.display=chk.checked?'block':'none';
}
function eUpdateSum(){
  var deps=0,recs=0;
  document.querySelectorAll('[id^="emov"][id$="-vd"]').forEach(function(e){deps+=eNum(e.value);});
  document.querySelectorAll('[id^="emov"][id$="-vr"]').forEach(function(e){recs+=eNum(e.value);});
  var totalDed=Object.values(eCredits).reduce(function(s,c){return s+(c.deduzido||0);},0);
  var saldo=totalDed-recs;
  eSetT('e-sv-dep',eBrl(deps));eSetT('e-sv-rec',eBrl(recs));eSetT('e-sv-saldo',eBrl(saldo));
}

