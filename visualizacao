<script>
/* ── mode switcher ── */
function setMode(m){
  var vis=document.getElementById('mode-vis');
  var edit=document.getElementById('mode-edit');
  if(m==='edit'){vis.style.display='none';edit.style.display='flex';}
  else{edit.style.display='none';vis.style.display='flex';}
}

/* ── vis JS ── */
function goTab(name,btn){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  document.getElementById('panel-'+name).classList.add('on');
  if(btn)btn.classList.add('on');
}
function togCard(hd){
  var body=hd.nextElementSibling;
  var svg=hd.querySelector('svg:last-child');
  if(!body)return;
  if(body.style.display==='none'){body.style.display='';if(svg)svg.style.transform='';}
  else{body.style.display='none';if(svg)svg.style.transform='rotate(-90deg)';}
}
function setFilter(btn){
  btn.closest('.reg-filters').querySelectorAll('.reg-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
}

/* ── edit JS ── */
function goEditTab(name){
  document.querySelectorAll('.e-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.e-panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('etab-btn-'+name).classList.add('active');
  document.getElementById('etab-'+name).classList.add('active');
}
function togECard(hd){hd.parentElement.classList.toggle('collapsed');}
function eToggleParc(){document.getElementById('e-parc-block').style.display=document.getElementById('e-chkParc').checked?'block':'none';}
function eBlurPct(el){var v=parseFloat(el.value.replace(',','.'))||0;el.value=v%1===0?v.toFixed(0):v.toFixed(2);}

/* utils */
function eNum(v){if(v==null)return 0;var s=String(v).replace(/R\$\s*/g,'').replace(/\./g,'').replace(',','.');return parseFloat(s.replace(/[^0-9.\-]/g,''))||0;}
function eBrl(v){var n=Number(v);var abs=Math.abs(n);var f='R$ '+abs.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});return n<0?'− '+f:f;}
function ePct(v){return Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2})+'%';}
function eSetT(id,v){var e=document.getElementById(id);if(e)e.textContent=v;}
function eSetI(id,v){var e=document.getElementById(id);if(e)e.value=v;}
function eMaskMoney(el){var raw=el.value.replace(/\D/g,'');if(raw===''){el.value='';return;}el.value=eBrl(parseInt(raw,10)/100);}

var eCCount=0,eCredits={};

function eAddCredit(){
  eCCount++;
  var n=eCCount,id='ecr'+n;
  eCredits[id]={bruto:0,ir:0,desagio:0,abatimento:0,deduzido:0,deposito:0,depTotal:0};
  var d=document.createElement('div');
  d.className='e-credit-item';d.id=id;
  d.innerHTML=
    '<div class="e-credit-hd"><span class="e-credit-lbl">Crédito '+n+'</span><button class="e-rm-btn" onclick="eRmCredit(\''+id+'\')">Remover</button></div>'+
    '<div class="e-row e-col2">'+
      '<div class="e-field"><label>Cedente</label><select><option value="">Selecione</option><option>Amélia Mascarenhas</option><option>João Silva</option><option>Maria Oliveira</option></select></div>'+
      '<div class="e-field"><label>Tipo de crédito</label><select><option value="">Selecione</option><option>Honorários</option><option>Condenação</option><option>Honorários + Condenação</option><option>Sucumbenciais</option><option>Contratuais com destaque</option><option>Contratuais sem destaque</option><option>Dativos</option></select></div>'+
    '</div>'+
    '<div class="e-row e-col2">'+
      '<div class="e-field"><label>Modelo de transação</label>'+
        '<div class="e-ms-wrap"><div class="e-ms-trigger" onclick="eToggleMs(\''+id+'-mod\')"><span class="e-ms-ph" id="'+id+'-mod-ph">Selecione</span></div>'+
        '<svg class="e-ms-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4l4 4 4-4"/></svg>'+
        '<div class="e-ms-dd" id="'+id+'-mod-dd">'+
          ['Não aguarda homologação','Aguarda homologação','Aguarda habilitação','Simples (normal total)','Modelo 50%','Deságio flexível'].map(function(m,i){
            var val=['nao_aguarda','aguarda_hom','aguarda_hab','simples','modelo50','desagio_flex'][i];
            return '<div class="e-ms-opt" onclick="eToggleModOpt(\''+id+'\',\''+val+'\',\''+m+'\',this)"><input type="checkbox" onclick="event.stopPropagation()"/> '+m+'</div>';
          }).join('')+
        '</div></div>'+
      '</div>'+
      '<div class="e-field"><label>Fase processual</label><select><option>Selecione</option><option>7.2 Cálculo homologado, já com petição</option></select></div>'+
    '</div>'+
    '<div id="'+id+'-df-wrap" style="display:none" class="e-df-block">'+
      '<div class="e-df-title">Deságio flexível</div>'+
      '<div class="e-row e-col4">'+
        '<div class="e-field"><label>Deságio flex (%)</label><input type="text" id="'+id+'-df-pct" placeholder="0%" oninput="eMaskMoney(this);eRcCredit(\''+id+'\')" onblur="eBlurPct(this);eRcCredit(\''+id+'\')"/></div>'+
        '<div class="e-field"><label>Dep. final flex</label><input class="e-calc" type="text" id="'+id+'-df-dep" readonly placeholder="R$ 0,00"/></div>'+
