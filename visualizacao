              <div class="grid3">
                <div class="frow"><span class="lbl">Unid. jud. padronizada</span><span class="val">2ª Itabuna</span></div>
                <div class="frow"><span class="lbl">UF</span><span class="val">SP</span></div>
                <div class="frow"><span class="lbl">Tribunal</span><span class="val">TRF1</span></div>
              </div>
              <div class="grid3">
                <div class="frow"><span class="lbl">Rito</span><span class="val">Sumário/Sumaríssimo</span></div>
                <div class="frow"><span class="lbl">Grau de jurisdição</span><span class="val">1ª instância</span></div>
                <div class="frow"><span class="lbl">Tipo do réu</span><span class="val">Privado — Concordância</span></div>
              </div>
              <div class="grid2">
                <div class="frow"><span class="lbl">Fase processual</span><span class="val">7.2 Cálculo homologado, já com petição</span></div>
                <div class="frow"><span class="lbl">Procuração pública</span><span class="val">Sim</span></div>
              </div>
            </div>
          </div>

          <!-- créditos resumo -->
          <div class="card">
            <div class="card-hd" onclick="togCard(this)">
              <span class="card-title">Créditos</span>
              <div style="display:flex;align-items:center;gap:8px">
                <span style="font-size:11px;color:#A3A3A3">2 créditos</span>
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="#A3A3A3" stroke-width="1.5"><path d="M2 4.5l4.5 4.5 4.5-4.5"/></svg>
              </div>
            </div>
            <div class="card-body" style="padding:8px 16px">
              <div class="credito-row" onclick="goTab('comercial', document.querySelector('.tab:nth-child(2)'))">
                <div class="credito-num">1</div>
                <div class="credito-info">
                  <div class="credito-cedente">Amélia Mascarenhas</div>
                  <div class="credito-tipo">Honorários contratuais · ID #CR-001</div>
                  <div style="margin-top:4px;display:flex;gap:4px;flex-wrap:wrap">
                    <span class="tag tag-modelo">Não aguarda homologação</span>
                    <span class="tag tag-modelo">Deságio flexível</span>
                  </div>
                </div>
                <div class="credito-vals">
                  <span class="credito-dep">R$ 7.290,00</span>
                  <span class="tag tag-wait-pay">Aguarda pagamento</span>
                </div>
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="#A3A3A3" stroke-width="1.5"><path d="M4 2l4 4-4 4"/></svg>
              </div>
              <div class="credito-row" onclick="goTab('comercial', document.querySelector('.tab:nth-child(2)'))">
                <div class="credito-num">2</div>
                <div class="credito-info">
                  <div class="credito-cedente">João Silva</div>
                  <div class="credito-tipo">Condenação · ID #CR-002</div>
                  <div style="margin-top:4px;display:flex;gap:4px;flex-wrap:wrap">
                    <span class="tag tag-modelo">Não aguarda homologação</span>
                    <span class="tag tag-modelo">Modelo 50%</span>
                  </div>
                </div>
                <div class="credito-vals">
                  <span class="credito-dep">R$ 12.150,00</span>
                  <span class="tag tag-wait-rec">Aguarda recebimento</span>
                </div>
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="#A3A3A3" stroke-width="1.5"><path d="M4 2l4 4-4 4"/></svg>
              </div>
            </div>
          </div>

          <!-- registros -->
          <div class="card">
            <div class="card-hd" onclick="togCard(this)">
              <span class="card-title">Registros</span>
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="#A3A3A3" stroke-width="1.5"><path d="M2 4.5l4.5 4.5 4.5-4.5"/></svg>
            </div>
            <div class="card-body">
              <div class="reg-filters">
                <button class="reg-btn on" onclick="setFilter(this)">Tudo</button>
                <button class="reg-btn" onclick="setFilter(this)">Alterações</button>
                <button class="reg-btn" onclick="setFilter(this)">Observações</button>
              </div>
              <div class="reg-input-wrap">
                <div class="avatar">AM</div>
                <textarea class="reg-textarea" placeholder="Digite sua observação aqui" rows="2"></textarea>
                <button class="icon-btn" style="color:#008633"><svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 1L1 6l5 2 2 5z"/><path d="M6 8l4-4"/></svg></button>
              </div>
              <p class="hint">Use @ para mencionar alguém e # para vincular uma transação.</p>
              <div class="search-wrap">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="#A3A3A3" stroke-width="1.5" style="position:absolute;left:9px;top:50%;transform:translateY(-50%)"><circle cx="5" cy="5" r="4"/><path d="M9 9l2 2"/></svg>
                <input class="search-input" placeholder="Pesquise por termo"/>
              </div>
              <div class="reg-card">
                <div style="padding:10px 12px 6px">
                  <div style="display:flex;align-items:center;gap:8px">
                    <div class="avatar">AM</div>
                    <div style="flex:1"><div style="font-size:12px;font-weight:600">Amélia Mascarenhas</div><div style="font-size:10px;color:#A3A3A3">40 minutos atrás</div></div>
                    <button class="icon-btn"><svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="3" cy="7" r="1"/><circle cx="7" cy="7" r="1"/><circle cx="11" cy="7" r="1"/></svg></button>
                  </div>
                </div>
                <div style="padding:0 12px 10px">
                  <p style="font-size:12px;line-height:1.6">Lorem ipsum dolor sit amet, <span class="mention">@Maria Souza</span> consectetur adipiscing <span class="link-tag">#22298</span></p>
                  <div class="reply-card">
                    <div style="display:flex;align-items:center;gap:7px;margin-bottom:5px">
                      <div class="avatar sm g">MS</div>
                      <span style="font-size:11px;font-weight:600">Maria Souza</span>
